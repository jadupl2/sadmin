#
# Ignored Compress Files Extensions, it's better to unpack these files and commit the raw source.
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.xcf
# Allow zip (have some in package directory pkg)
#*.zip

# Ignore these files extensions
*.obj
*.pdb
*.bak
*.log
*.cache
*.org
*.tmp

# Ignore Python Related files andEnsure that package util-linux is installed on client & server.
# Ignore MacOS related custom attributes of its containing folder
.DS_Store
.DS_Store?
._.DS_Store

# Ignore Windows Related files.
[Tt]humbs.db

# Ignore Linux related files
.bash_history
.bash_profile
.bashrc
.vscode
.viminfo
.mysql_history
.Trash-*/
.vscode/
bitbucket-pipelines.yml



# --------------------------------------
# SADMIN PROJECT 
# -------------------------------------- 

# Exclude the SADMIN System monitor lock file.
sysmon.lock
readme.html
readme.pdf
lib/__pycache__/
bin/__pycache__/

# Exclude don't want in repository (old stuff Directories)
old2keep/*
nogit/*

# Want theses directories to be part of the project (but empty only .gitkeep)
dat/*
!dat/.gitkeep
log/*
!log/.gitkeep
tmp/*
!tmp/.gitkeep


# System startup & Shutdown Scripts, Used if sadmin.service is enabled.
sys/*
!sys/.gitkeep
!sys/.sadm_shutdown.sh
!sys/.sadm_startup.sh

# Specifying the 'usr' sub-directories to exist, with only '.gitkeep' file in them .
usr/cfg/*
!usr/cfg/.gitkeep
usr/dat/*
!usr/dat/.gitkeep
usr/bin/*
!usr/bin/.gitkeep
usr/doc/*
!usr/doc/.gitkeep
usr/lib/*
!usr/lib/.gitkeep
usr/mon/*
!usr/mon/.gitkeep


# Scripts that can be executed by specifying them in hostname.smon
!usr/mon/sysmon_script_test.sh
!usr/mon/srestart.sh
!usr/mon/stemplate.txt
!usr/mon/stemplate.sh
!usr/mon/swatch_nmon.sh
!usr/mon/swatch_nmon.txt


# Want these WebSite directories to be part of project (but empty)
www/dat/*
!www/dat/.gitkeep
www/tmp/*
!www/tmp/.gitkeep
!www/tmp/perf/.gitkeep
www/rrd/*
!www/rrd/.gitkeep
www/view/daily*
www/test/*


# Files in cfg directory that are part of SADMIN package
cfg/*
!cfg/.sadmin.cfg
!cfg/sadmin_client.cfg
!cfg/.alert_group.cfg
!cfg/.alert_slack.cfg
!cfg/.alert_history.txt
!cfg/.alert_archive.txt
!cfg/.template.smon
!cfg/.release
!cfg/.version
!cfg/.versum
!cfg/.backup_list.txt
!cfg/.backup_exclude.txt
!cfg/.rear_exclude.txt
!cfg/.sadmin.service
!cfg/.sadmin.rc
!cfg/.gitkeep
!cfg/.sadm_link_2doc.cfg
!cfg/.sadm_vm_exclude_start.txt

# Setup Directory
setup/update/*
!setup/update/.gitkeep

# HTML Report Generated Daily (Not used now)
www/view/daily_backup_report.html
www/view/daily_rear_report.html
www/view/daily_scripts_report.html
www/view/daily_storix_report.html
